{
  "$schema": "component-spec-v1",
  "name": "ogn/app-bar",
  "category": "ogn",
  "description": "앱 상단 AppBar. RightItem·Title·LeftItem·Logo on/off.",
  "base": {
    "layout": {
      "mode": "HORIZONTAL",
      "paddingTop": 10.0,
      "paddingRight": 20.0,
      "paddingBottom": 10.0,
      "paddingLeft": 20.0,
      "primaryAxisSizingMode": "FIXED",
      "counterAxisAlignItems": "CENTER",
      "width": "FILL"
    },
    "visual": {},
    "children": [
      {
        "kind": "group",
        "id": "title",
        "layout": {
          "mode": "HORIZONTAL",
          "itemSpacing": 4.0,
          "primaryAxisSizingMode": "FIXED",
          "counterAxisAlignItems": "CENTER",
          "width": "HUG"
        },
        "visual": {},
        "children": [
          {
            "kind": "group",
            "id": "btn",
            "layout": {
              "mode": "HORIZONTAL",
              "itemSpacing": 10.0,
              "paddingTop": 2.0,
              "paddingRight": 2.0,
              "paddingBottom": 2.0,
              "paddingLeft": 2.0,
              "counterAxisAlignItems": "CENTER",
              "width": "HUG"
            },
            "visual": {},
            "children": [
              {
                "kind": "ref",
                "id": "-ico",
                "component": ".Ico"
              }
            ]
          },
          {
            "kind": "text",
            "id": "title",
            "content": "결제하기",
            "exposeAs": "title"
          }
        ]
      },
      {
        "kind": "group",
        "id": "rightitem",
        "layout": {
          "mode": "HORIZONTAL",
          "itemSpacing": 12.0,
          "primaryAxisAlignItems": "MAX",
          "counterAxisAlignItems": "CENTER",
          "width": "HUG"
        },
        "visual": {},
        "children": [
          {
            "kind": "group",
            "id": "btn",
            "layout": {
              "mode": "VERTICAL",
              "itemSpacing": 10.0,
              "paddingTop": 2.0,
              "paddingRight": 2.0,
              "paddingBottom": 2.0,
              "paddingLeft": 2.0,
              "width": "HUG"
            },
            "visual": {},
            "children": [
              {
                "kind": "ref",
                "id": "-ico",
                "component": ".Ico"
              }
            ]
          },
          {
            "kind": "group",
            "id": "btn",
            "layout": {
              "mode": "HORIZONTAL",
              "itemSpacing": 10.0,
              "paddingTop": 2.0,
              "paddingRight": 2.0,
              "paddingBottom": 2.0,
              "paddingLeft": 2.0,
              "counterAxisAlignItems": "CENTER",
              "width": "HUG"
            },
            "visual": {},
            "children": [
              {
                "kind": "ref",
                "id": "-ico",
                "component": ".Ico"
              }
            ]
          }
        ]
      }
    ]
  },
  "variants": {
    "axes": [
      {
        "name": "rightitem",
        "values": [
          "on",
          "off"
        ]
      },
      {
        "name": "title",
        "values": [
          "on",
          "off"
        ]
      },
      {
        "name": "leftitem",
        "values": [
          "on",
          "off"
        ]
      },
      {
        "name": "logo",
        "values": [
          "off",
          "on"
        ]
      }
    ],
    "overrides": {}
  }
}