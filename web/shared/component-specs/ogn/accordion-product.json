{
  "$schema": "component-spec-v1",
  "name": "ogn/accordion-product",
  "category": "ogn",
  "description": "상품 정보 아코디언. Open/Default.",
  "base": {
    "layout": {
      "mode": "VERTICAL",
      "itemSpacing": 10.0,
      "paddingTop": 24.0,
      "paddingRight": 24.0,
      "paddingBottom": 24.0,
      "paddingLeft": 24.0,
      "counterAxisSizingMode": "FIXED",
      "width": "HUG"
    },
    "visual": {
      "cornerRadius": 20.0,
      "fill": "#f4f5fa"
    },
    "children": [
      {
        "kind": "group",
        "id": "title",
        "layout": {
          "mode": "HORIZONTAL",
          "itemSpacing": 101.0,
          "primaryAxisSizingMode": "FIXED",
          "primaryAxisAlignItems": "SPACE_BETWEEN",
          "counterAxisAlignItems": "CENTER",
          "width": "HUG"
        },
        "visual": {},
        "children": [
          {
            "kind": "group",
            "id": "leftitem",
            "layout": {
              "mode": "HORIZONTAL",
              "itemSpacing": 12.0,
              "counterAxisAlignItems": "CENTER",
              "width": "HUG"
            },
            "visual": {},
            "children": [
              {
                "kind": "ref",
                "id": "-thumbnaillogoitem",
                "component": ".ThumbnailLogoItem"
              }
            ]
          },
          {
            "kind": "ref",
            "id": "-ico",
            "component": ".Ico"
          }
        ]
      }
    ]
  },
  "variants": {
    "axes": [
      {
        "name": "states",
        "values": [
          "open",
          "default"
        ]
      }
    ],
    "overrides": {}
  }
}