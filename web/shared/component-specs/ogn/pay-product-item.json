{
  "$schema": "component-spec-v1",
  "name": "ogn/pay-product-item",
  "category": "ogn",
  "description": "결제/장바구니 상품 목록 아이템. Type(Pay/Cart).",
  "base": {
    "layout": {
      "mode": "VERTICAL",
      "itemSpacing": 12.0,
      "paddingBottom": 8.0,
      "counterAxisSizingMode": "FIXED",
      "counterAxisAlignItems": "CENTER",
      "width": "HUG"
    },
    "visual": {},
    "children": [
      {
        "kind": "group",
        "id": "local_listitem",
        "layout": {
          "mode": "HORIZONTAL",
          "itemSpacing": 12.0,
          "primaryAxisSizingMode": "FIXED",
          "width": "HUG"
        },
        "visual": {},
        "children": [
          {
            "kind": "ref",
            "id": "-thumbnailitem",
            "component": ".ThumbnailItem"
          },
          {
            "kind": "group",
            "id": "text",
            "layout": {
              "mode": "VERTICAL",
              "itemSpacing": 8.0,
              "counterAxisSizingMode": "FIXED",
              "width": "HUG"
            },
            "visual": {}
          }
        ]
      },
      {
        "kind": "ref",
        "id": "-buttontextunderline",
        "component": ".ButtonTextUnderline"
      }
    ]
  },
  "variants": {
    "axes": [
      {
        "name": "type",
        "values": [
          "pay",
          "cart"
        ]
      }
    ],
    "overrides": {}
  }
}