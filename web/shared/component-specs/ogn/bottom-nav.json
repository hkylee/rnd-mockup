{
  "$schema": "component-spec-v1",
  "name": "ogn/bottom-nav",
  "category": "ogn",
  "description": "하단 내비게이션. State(My/Search/Shopping).",
  "base": {
    "layout": {
      "mode": "HORIZONTAL",
      "itemSpacing": 12.0,
      "paddingTop": 12.0,
      "paddingBottom": 36.0,
      "primaryAxisSizingMode": "FIXED",
      "primaryAxisAlignItems": "CENTER",
      "counterAxisAlignItems": "CENTER",
      "width": "FILL"
    },
    "visual": {
      "fill": "{component.progress.small.track}",
      "stroke": "#f4f5fa"
    },
    "children": [
      {
        "kind": "group",
        "id": "my",
        "layout": {
          "mode": "VERTICAL",
          "itemSpacing": 2.0,
          "paddingRight": 5.0,
          "paddingLeft": 5.0,
          "counterAxisSizingMode": "FIXED",
          "counterAxisAlignItems": "CENTER",
          "width": "HUG"
        },
        "visual": {},
        "children": [
          {
            "kind": "ref",
            "id": "-ico",
            "component": ".Ico"
          },
          {
            "kind": "text",
            "id": "my",
            "content": "MY",
            "exposeAs": "my"
          }
        ]
      },
      {
        "kind": "group",
        "id": "search",
        "layout": {
          "mode": "VERTICAL",
          "itemSpacing": 2.0,
          "paddingRight": 5.0,
          "paddingLeft": 5.0,
          "counterAxisSizingMode": "FIXED",
          "counterAxisAlignItems": "CENTER",
          "width": "HUG"
        },
        "visual": {},
        "children": [
          {
            "kind": "ref",
            "id": "-ico",
            "component": ".Ico"
          },
          {
            "kind": "text",
            "id": "--",
            "content": "검색",
            "exposeAs": "--"
          }
        ]
      },
      {
        "kind": "group",
        "id": "shopping",
        "layout": {
          "mode": "VERTICAL",
          "itemSpacing": 2.0,
          "paddingRight": 5.0,
          "paddingLeft": 5.0,
          "counterAxisSizingMode": "FIXED",
          "counterAxisAlignItems": "CENTER",
          "width": "HUG"
        },
        "visual": {},
        "children": [
          {
            "kind": "ref",
            "id": "-ico",
            "component": ".Ico"
          },
          {
            "kind": "text",
            "id": "--",
            "content": "쇼핑",
            "exposeAs": "--"
          }
        ]
      }
    ]
  },
  "variants": {
    "axes": [
      {
        "name": "state",
        "values": [
          "my",
          "search",
          "shopping"
        ]
