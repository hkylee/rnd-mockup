{
  "$schema": "component-spec-v1",
  "name": "ogn/text-field",
  "category": "ogn",
  "description": "텍스트필드. States(Default/Focused/Typing/Typed/Disabled) × Error.",
  "base": {
    "layout": {
      "mode": "VERTICAL",
      "itemSpacing": 8.0,
      "paddingBottom": 8.0,
      "counterAxisSizingMode": "FIXED",
      "primaryAxisAlignItems": "MAX",
      "width": "HUG"
    },
    "visual": {},
    "children": [
      {
        "kind": "ref",
        "id": "label",
        "component": "Label"
      },
      {
        "kind": "ref",
        "id": "textfielddefault",
        "component": "TextFieldDefault"
      },
      {
        "kind": "group",
        "id": "help-text",
        "layout": {
          "mode": "VERTICAL",
          "itemSpacing": 10.0,
          "counterAxisSizingMode": "FIXED",
          "width": "HUG"
        },
        "visual": {},
        "children": [
          {
            "kind": "text",
            "id": "help-text",
            "content": "Help Text",
            "exposeAs": "help-text"
          }
        ]
      }
    ]
  },
  "variants": {
    "axes": [
      {
        "name": "states",
        "values": [
          "default",
          "disabled",
          "focused",
          "typed",
          "typing"
        ]
      },
      {
        "name": "error",
        "values": [
          "on",
          "off"
        ]
      }
    ],
    "overrides": {}
  }
}