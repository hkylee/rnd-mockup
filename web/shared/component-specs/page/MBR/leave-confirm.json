                "layoutAlign": "STRETCH" }
            ]
          },
          {
            "kind": "ref", "id": "confirm-card", "component": "ogn/MBR/leave-confirm-card",
            "layoutAlign": "STRETCH",
            "_comment": "[고지·필수] POL-MBR-LEAVE-007/011"
          }
        ],
        "layoutGrow": 1
      },
      { "kind": "ref", "id": "sticky-footer", "component": "ogn/sticky-footer-cta", "props": { "label": "탈퇴 확정" }, "layoutAlign": "STRETCH", "scrollBehavior": "STICKY_SCROLLS" },
      { "kind": "ref", "id": "footer-cs", "component": "ogn/footer-cs", "layoutAlign": "STRETCH", "scrollBehavior": "STICKY_SCROLLS" }
