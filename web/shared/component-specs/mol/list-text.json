{
  "$schema": "component-spec-v1",
  "name": "mol/list-text",
  "category": "mol",
  "description": "텍스트 목록 행. RightItem × Table 타입.",
  "base": {
    "layout": {
      "mode": "HORIZONTAL",
      "itemSpacing": 16.0,
      "paddingBottom": 4.0,
      "primaryAxisSizingMode": "FIXED",
      "counterAxisAlignItems": "CENTER",
      "width": "FILL"
    },
    "visual": {},
    "children": [
      {
        "kind": "group",
        "id": "leftitem",
        "layout": {
          "mode": "HORIZONTAL",
          "primaryAxisSizingMode": "FIXED",
          "counterAxisAlignItems": "CENTER",
          "width": "HUG"
        },
        "visual": {},
        "children": [
          {
            "kind": "text",
            "id": "text",
            "content": "타이틀 레이블",
            "exposeAs": "text"
          }
        ]
      },
      {
        "kind": "ref",
        "id": "-rightitem",
        "component": ".RightItem"
      }
    ]
  },
  "variants": {
    "axes": [
      {
        "name": "table",
        "values": [
          "off",
          "on",
          "dot",
          "첫번째-강조-타이틀",
          "두번째-강조-타이틀"
        ]
      }
    ],
    "overrides": {}
  }
}