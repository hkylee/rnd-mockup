{
  "$schema": "component-spec-v1",
  "name": "atom/btn-xsmall",
  "category": "atom",
  "description": "소형 솔리드 버튼. Active/Disabled.",
  "base": {
    "layout": {
      "mode": "HORIZONTAL",
      "paddingTop": 4.0,
      "paddingRight": 7.0,
      "paddingBottom": 4.0,
      "paddingLeft": 7.0,
      "primaryAxisAlignItems": "CENTER",
      "counterAxisAlignItems": "CENTER",
      "width": "HUG"
    },
    "visual": {
      "cornerRadius": 99.0,
      "fill": "#05001a"
    },
    "children": [
      {
        "kind": "text",
        "id": "-----",
        "content": "쿠폰 받기",
        "exposeAs": "-----"
      },
      {
        "kind": "ref",
        "id": "-ico",
        "component": ".Ico"
      }
    ]
  },
  "variants": {
    "axes": [
      {
        "name": "state",
        "values": [
          "active",
          "disabled"
        ]
      }
    ],
    "overrides": {}
  }
}