{
  "$schema": "component-spec-v1",
  "name": "atom/tooltip",
  "category": "atom",
  "description": "툴팁 버블. Direction(Left/Center/Right).",
  "base": {
    "layout": {
      "mode": "VERTICAL",
      "width": "HUG"
    },
    "visual": {},
    "children": [
      {
        "kind": "group",
        "id": "bubble",
        "layout": {
          "mode": "HORIZONTAL",
          "itemSpacing": 10.0,
          "paddingTop": 6.0,
          "paddingRight": 12.0,
          "paddingBottom": 6.0,
          "paddingLeft": 12.0,
          "primaryAxisAlignItems": "CENTER",
          "counterAxisAlignItems": "CENTER",
          "width": "HUG"
        },
        "visual": {
          "cornerRadius": 99.0,
          "fill": "{component.radio.default.dotColor}"
        },
        "children": [
          {
            "kind": "text",
            "id": "----14-900-",
            "content": "선물가 14,900원",
            "exposeAs": "----14-900-"
          }
        ]
      },
      {
        "kind": "group",
        "id": "tail",
        "layout": {
          "mode": "VERTICAL",
          "itemSpacing": 10.0,
          "paddingRight": 20.0,
          "paddingLeft": 20.0,
          "counterAxisSizingMode": "FIXED",
          "width": "HUG"
        },
        "visual": {}
      }
    ]
  },
  "variants": {
    "axes": [
      {
        "name": "direction",
        "values": [
          "left",
          "center",
          "right"
        ]
      }
    ],
    "overrides": {}
  }
}