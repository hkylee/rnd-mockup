{
  "$schema": "component-spec-v1",
  "name": "atom/btn",
  "category": "atom",
  "description": "버튼. Size(Small~XLarge) × Type(Primary/Secondary/Disabled). LeftItem 슬롯.",
  "base": {
    "layout": {
      "mode": "HORIZONTAL",
      "itemSpacing": 10.0,
      "paddingTop": 6.0,
      "paddingRight": 12.0,
      "paddingBottom": 6.0,
      "paddingLeft": 12.0,
      "primaryAxisAlignItems": "CENTER",
      "counterAxisAlignItems": "CENTER",
      "width": "HUG"
    },
    "visual": {
      "cornerRadius": "{foundation.dimension.radius.pill}",
      "fill": "{component.radio.default.fillSelected}"
    },
    "children": [
      {
        "kind": "text",
        "id": "--",
        "content": "버튼",
        "exposeAs": "--"
      }
    ]
  },
  "variants": {
    "axes": [
      {
        "name": "size",
        "values": [
          "small",
          "medium",
          "large",
          "xlarge"
        ]
      },
      {
        "name": "type",
        "values": [
          "primary",
          "secondary",
          "disabled"
        ]
      }
    ],
    "overrides": {}
  }
}