{
  "$schema": "component-spec-v1",
  "name": "atom/chip-image",
  "category": "atom",
  "description": "이미지+텍스트 칩. Selected On/Off.",
  "base": {
    "layout": {
      "mode": "HORIZONTAL",
      "itemSpacing": 2.0,
      "paddingTop": 10.0,
      "paddingRight": 16.0,
      "paddingBottom": 10.0,
      "paddingLeft": 12.0,
      "counterAxisAlignItems": "CENTER",
      "width": "HUG"
    },
    "visual": {
      "cornerRadius": 999.0,
      "fill": "{component.radio.default.dotColor}"
    },
    "children": [
      {
        "kind": "ref",
        "id": "-ico",
        "component": ".Ico"
      },
      {
        "kind": "text",
        "id": "---",
        "content": "단말기",
        "exposeAs": "---"
      }
    ]
  },
  "variants": {
    "axes": [
      {
        "name": "selected",
        "values": [
          "on",
          "off"
        ]
      }
    ],
    "overrides": {}
  }
}