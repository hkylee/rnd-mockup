      "minHeight": "{foundation.dimension.size.screen-mobile-height}",
      "height": "{foundation.dimension.size.screen-mobile-height}"
    },
    "visual": { "cornerRadius": 0, "fill": "{semantic.color.background.page-sub}", "stroke": null, "shadow": null },
    "children": [
      { "kind": "ref", "id": "status-bar", "component": "ogn/status-bar" },
      { "kind": "ref", "id": "header", "component": "ogn/header", "props": { "title": "회원 탈퇴" } },
