{
  "$schema": "component-spec-v1",
  "name": "page/MBR/leave-reason",
  "category": "page",
  "description": "회원 탈퇴 2/5 — 사유 입력. POL-MBR-LEAVE-001. Pattern B. 5 사유 (mol/checkbox-item input=radio) + 직접 입력 form-row.",
  "base": {
    "layout": {
