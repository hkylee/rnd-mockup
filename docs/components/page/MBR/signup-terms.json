      { "kind": "ref", "id": "footer-cs", "component": "ogn/footer-cs", "layoutAlign": "STRETCH", "scrollBehavior": "STICKY_SCROLLS", "_comment": "[고지·필수] 전기통신사업법 § 22-2" }
